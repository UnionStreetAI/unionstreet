{
  "name": "@unionstreet/us",
  "version": "0.0.1",
  "private": false,
  "license": "MIT",
  "description": "Union Street — local-first multi-agent runtime, us CLI, server, SDK, and provider auth.",
  "homepage": "https://github.com/UnionStreetAI/unionstreet#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/UnionStreetAI/unionstreet.git",
    "directory": "packages/npm"
  },
  "bugs": {
    "url": "https://github.com/UnionStreetAI/unionstreet/issues"
  },
  "keywords": [
    "agents",
    "multi-agent",
    "cli",
    "mcp",
    "lash",
    "runtime",
    "agent-framework",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "us": "bin/us"
  },
  "files": [
    ".pack",
    "bin"
  ],
  "imports": {
    "@unionstreet/server": "./.pack/server/src/index.ts",
    "@unionstreet/us-auth": "./.pack/us-auth/src/index.ts",
    "@unionstreet/us-auth/oauth": "./.pack/us-auth/src/oauth/index.ts",
    "@unionstreet/ai-codex": "./.pack/ai-codex/src/index.ts",
    "@unionstreet/sdk": "./.pack/sdk/src/index.ts"
  },
  "exports": {
    ".": "./.pack/us-cli/src/index.ts",
    "./cli": "./.pack/us-cli/src/index.ts",
    "./server": "./.pack/server/src/index.ts",
    "./sdk": "./.pack/sdk/src/index.ts",
    "./auth": "./.pack/us-auth/src/index.ts",
    "./auth/oauth": "./.pack/us-auth/src/oauth/index.ts",
    "./codex": "./.pack/ai-codex/src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepack": "bun run ../../scripts/stage-npm-package.ts",
    "pack:verify": "bun run ../../scripts/stage-npm-package.ts && npm pack --dry-run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@lashprotocol/lash": "^0.1.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentui/core": "^0.2.1",
    "@opentui/react": "^0.2.1",
    "ai": "^5.0.0",
    "cac": "^6.7.14",
    "js-yaml": "^4.1.0",
    "kleur": "^4.1.5",
    "open": "^10.1.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.0.0",
    "zod": "^3.23.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
