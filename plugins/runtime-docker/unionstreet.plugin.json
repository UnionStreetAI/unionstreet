{
  "schema_version": "v1",
  "name": "runtime-docker",
  "version": "0.1.0",
  "description": "Union Street Docker runtime provider: container compute, volume-backed storage, and host-routed ingress.",
  "kind": ["runtime"],
  "capabilities": {
    "runtime": ["render", "apply", "status", "destroy", "terraform"],
    "tools": [],
    "hooks": [],
    "mcp": [],
    "skills": []
  },
  "entrypoints": {
    "terraform": "./terraform"
  },
  "permissions": {
    "network": ["docker-daemon"],
    "filesystem": ["workspace"],
    "secrets": ["runtime:*"],
    "subprocess": true
  }
}
